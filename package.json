{
  "name": "agentcoop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "bin": {
    "agentcoop": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "check": "biome ci --error-on-warnings .",
    "fix": "biome check --write src",
    "format": "biome format --write",
    "lint": "biome check",
    "test": "tsc && vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/node": "^24",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "ink": "^7.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.4",
    "string-width": "^8.2.0",
    "wrap-ansi": "^10.0.0"
  }
}
